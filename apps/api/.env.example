# apps/api local environment. Copy to apps/api/.env and fill in. NEVER commit .env.
# (dotenv loads this file from the api's working directory.)

# Port the API listens on locally (Render injects PORT in deployed envs).
API_PORT=3001

# Privileged DB connection (owner/superuser): runs migrations and auth bootstrap
# (register/login/refresh). Bypasses RLS by design. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/planningos_dev

# Application DB connection: the NON-superuser `planningos_app` role used for all
# tenant-scoped queries. RLS policies apply to it. Provision the role first:
#   psql "$DATABASE_URL" -v app_password="<pw>" -f scripts/setup-app-role.sql
APP_DATABASE_URL=postgres://planningos_app:<app_password>@localhost:5432/planningos_dev

# JWT secrets — generate per environment, never reuse. e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Sentry — leave blank locally to keep Sentry inert (no events sent).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
