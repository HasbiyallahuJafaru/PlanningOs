# apps/api local environment. Copy to apps/api/.env and fill in. NEVER commit .env.
# (dotenv loads this file from the api's working directory.)

# Port the API listens on locally (Render injects PORT in deployed envs).
API_PORT=3001

# Local Postgres connection string. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/planningos_dev

# Sentry — leave blank locally to keep Sentry inert (no events sent).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
