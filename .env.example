# PlanningOS — example environment file.
# Copy to .env (api reads it) and fill in real values. NEVER commit .env. See 07_DEPLOYMENT.md.

# --- API ---
# Port the NestJS API listens on locally
API_PORT=3001

# --- Database (local Postgres for dev; Render managed Postgres, EU/UK region, in deployed envs) ---
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://postgres:postgres@localhost:5432/planningos_dev

# --- Sentry (error monitoring, wired from first commit per 02_ARCHITECTURE.md) ---
# Leave blank locally to disable; set the real DSN in Render's secret manager for deployed envs.
SENTRY_DSN=
# Environment label reported to Sentry: development | staging | production
SENTRY_ENVIRONMENT=development

# --- Web (Next.js) ---
# Base URL the web app uses to reach the API
NEXT_PUBLIC_API_URL=http://localhost:3001
